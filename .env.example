# =========================================================================
# Kushvi Closet - Production Environment Template
# Duplicate this file to '.env.local' and populate it with your real credentials.
# =========================================================================

# 1. Supabase (Database, Auth, Storage)
# Locate these in your Supabase Dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key # Server-side only (keeps database security triggers running)

# 2. Google OAuth (For Customer / Vendor logins)
# Locate these in your Google Cloud Console under Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 3. Google Cloud Vision API (For Pinterest Visual Search)
# Enable the Cloud Vision API on Google Cloud Console and generate an API Key
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# 4. Fashn AI (For Virtual Try-On)
# Register at fashn.ai and get your API Key from the dashboard
FASHN_API_KEY=your-fashn-api-key

# 5. Razorpay Payments
# Generate these in Razorpay Dashboard > Settings > API Keys (Test/Live mode keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# 6. General Site URL (For SEO/Metadata base resolution)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
